# parsarr configuration
# Copy this file to config.yaml and fill in your values.
# config.yaml is gitignored and should never be committed.

# Directory where parsarr stages reorganized files before import.
# This path must be readable and writable by parsarr, Sonarr, and Radarr.
staging_dir: /data/staging

sonarr:
  url: http://sonarr:8989
  api_key: YOUR_SONARR_API_KEY   # Sonarr → Settings → General → API Key

radarr:
  url: http://radarr:7878
  api_key: YOUR_RADARR_API_KEY   # Radarr → Settings → General → API Key

# Optional webhook secret.
# If set, parsarr validates incoming requests against the X-Parsarr-Secret header.
# Set the same value in your Sonarr/Radarr webhook connection settings.
webhook_secret: ""

# Python log level: DEBUG, INFO, WARNING, ERROR
log_level: INFO

# Port the webhook server listens on
port: 8080

# Bonus-content detection patterns.
# Any video file whose name contains one of these strings (case-insensitive)
# is classified as an extra and moved to _extras/ instead of a Season folder.
# These are merged with the built-in pattern list — you don't need to repeat
# the defaults here unless you want to override the entire list.
#
# extra_patterns:
#   - "my custom pattern"
