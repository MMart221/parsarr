# parsarr configuration
# Copy this file to config.yaml and fill in your values.
# config.yaml is gitignored and should never be committed.

sonarr:
  url: http://sonarr:8989
  api_key: YOUR_SONARR_API_KEY   # Sonarr → Settings → General → API Key

qbittorrent:
  url: http://qbittorrent:8080
  username: admin
  password: adminadmin

# qBittorrent category Parsarr uses for rerouted and manual torrents.
# Create this category in qBittorrent first.
# Sonarr must NOT be configured to auto-import from this category.
parsarr_category: parsarr-managed

# Where qBittorrent downloads problematic releases while Parsarr owns them.
# Sonarr never sees this directory.
managed_download_dir: /media/downloads/managed

# Parsarr's temporary work area for reorganizing files before final placement.
staging_dir: /media/staging

# Final library destinations. Parsarr places cleaned files directly here.
media_roots:
  tv: /media/tv
  anime: /media/anime

# How Parsarr moves cleaned files into the final library path.
# Allowed values: move, copy, hardlink
placement_mode: move

# Path to the SQLite database for job tracking.
db_path: /data/parsarr.db

# Optional webhook secret — set the same value in Sonarr's webhook connection.
webhook_secret: ""

log_level: INFO
port: 8080

# Additional bonus-content detection patterns (case-insensitive substring match).
# The built-in list is always active. Add custom patterns here if needed.
# extra_patterns:
#   - "my custom pattern"
